# Copy to `.dev.vars` for local `wrangler dev`. NEVER commit the real .dev.vars.
# In production these are set with `wrangler secret put <NAME>` instead.

# The shared DeepSeek API key. This is the ONLY place it lives — never in the app.
DEEPSEEK_API_KEY="sk-your-deepseek-key"

# Random secret used to sign Pulse session tokens (HS256). Generate with:
#   openssl rand -base64 48
SESSION_SIGNING_SECRET="replace-with-a-long-random-string"

# Protects /admin/topup and /admin/status. Generate another random string.
ADMIN_SECRET="replace-with-another-random-string"
